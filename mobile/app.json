{
  "expo": {
    "name": "Worldly",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.simmyd23.worldly",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.simmyd23.worldly",
      "adaptiveIcon": {
        "backgroundColor": "#14213D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "userInterfaceStyle": "light"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#14213D"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Worldly uses your location to add the city and country you're visiting to your travel map.",
          "locationAlwaysAndWhenInUsePermission": "Worldly uses your location in the background during a trip to automatically add the cities and countries you visit to your map.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Worldly accesses your photos so you can set a profile picture and add photos to your discoveries and trips.",
          "cameraPermission": "Worldly uses your camera so you can take a profile picture or a photo for a discovery."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Worldly accesses your photo library to find geotagged photos and detect the countries and cities you've visited.",
          "savePhotosPermission": "Worldly saves a photo to your library when you choose to.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Worldly uses your contacts so you can invite friends you already know to your travel circle."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Worldly uses your camera to scan a friend's Worldly QR code and connect with them."
        }
      ],
      "@sentry/react-native",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.495314900593-7m5rjdob53fnihjii0ubk73fsloitqef"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31d88642-eb0d-4c42-8642-7637ce0a3701"
      }
    },
    "owner": "simmyd23",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/31d88642-eb0d-4c42-8642-7637ce0a3701"
    }
  }
}