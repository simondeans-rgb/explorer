rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }
    function createIsOwner() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Deterministic connection id for the (me, other) pair, sorted so both
    // members resolve to the same document.
    function connId(other) {
      return request.auth.uid < other
        ? request.auth.uid + '__' + other
        : other + '__' + request.auth.uid;
    }
    function isFriendOf(ownerId) {
      return signedIn()
        && exists(/databases/$(database)/documents/connections/$(connId(ownerId)))
        && get(/databases/$(database)/documents/connections/$(connId(ownerId))).data.status == 'accepted';
    }
    // Owner always; an accepted friend may read.
    function sharedRead(ownerId) {
      return signedIn() && (ownerId == request.auth.uid || isFriendOf(ownerId));
    }

    match /places/{placeId} {
      allow read: if sharedRead(resource.data.userId);
      allow create: if createIsOwner();
      allow update, delete: if isOwner();
    }

    match /discoveries/{discoveryId} {
      allow read: if sharedRead(resource.data.userId);
      allow create: if createIsOwner();
      allow update, delete: if isOwner();
    }

    // Expeditions stay private to their owner.
    match /expeditions/{expeditionId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    // Photo captures stay private to their owner.
    match /captures/{captureId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    // Saved bookmarks stay private to their owner.
    match /saved/{savedId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    // Planned trips stay private to their owner.
    match /trips/{tripId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    // Member profile, looked up by uid once you're connected. No listing.
    match /profiles/{uid} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // code -> uid resolver, fetched by exact id only (no enumeration).
    match /codes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Friendships / requests between exactly two members.
    match /connections/{id} {
      // `resource` is null when the doc doesn't exist yet — allow the read so
      // the client can check "is there already a request?" before creating one.
      allow read: if signedIn()
        && (resource == null || request.auth.uid in resource.data.members);
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.members.size() == 2;
      allow update: if signedIn()
        && request.auth.uid in resource.data.members
        && request.auth.uid in request.resource.data.members;
      allow delete: if signedIn() && request.auth.uid in resource.data.members;
    }
  }
}
