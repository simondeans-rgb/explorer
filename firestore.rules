rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Every Passport collection follows the same per-Member isolation pattern:
    // a document is only readable/writable by the Member whose uid it carries.
    function isOwner() {
      return request.auth != null
        && resource.data.userId == request.auth.uid;
    }
    function createIsOwner() {
      return request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /places/{placeId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    // Reserved for upcoming areas — same ownership model.
    match /expeditions/{expeditionId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }

    match /discoveries/{discoveryId} {
      allow read, update, delete: if isOwner();
      allow create: if createIsOwner();
    }
  }
}
