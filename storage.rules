rules_version = '2';

// Photos live under users/{uid}/… — each Member writes only their own folder.
// Reads are allowed for any signed-in Member (download URLs are token-gated and
// shared via the owner's Firestore docs, so connected friends can view them).
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
