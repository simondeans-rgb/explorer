rules_version = '2';

// Photos live under users/{uid}/… — each Member reads/writes only their own
// folder. Connected friends still view shared photos via the token-gated
// download URLs stored in the owner's Firestore docs (those bypass these rules),
// so scoping reads to the owner closes broad cross-user access without breaking
// sharing.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
